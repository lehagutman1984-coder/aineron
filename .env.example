DEBUG=0
DJANGO_ALLOWED_HOSTS=aineron.ru www.aineron.ru localhost 127.0.0.1

# PostgreSQL
POSTGRES_DB=neiro_db
POSTGRES_USER=neiro_user
POSTGRES_PASSWORD=

DB_HOST=db
DB_NAME=neiro_db
DB_USER=neiro_user
DB_PASSWORD=
DB_PORT=5432

# Redis / Celery
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_SSL=False
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Payments
ROBOKASSA_LOGIN=
ROBOKASSA_PASS1=
ROBOKASSA_PASS2=
ROBOKASSA_TEST_MODE=1

# AI providers
LAOZHANG_API_KEY=       # api.laozhang.ai — text/image models
APIMART_API_KEY=        # apimart.ai — video models (Sora, Veo, Kling)
TAVILY_API_KEY=         # tavily.com — web search (1000 req/month free)

# Site
SECRET_KEY=
SITE_URL=https://aineron.ru
SITE_NAME=aineron.ru

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=https://aineron.ru/api

# ===== Studio (Vibe-Coding) =====
# Agent prompt language: 'en' (default) or 'ru'
STUDIO_PROMPT_LANG=en

# Watchdog thresholds
STUDIO_STEP_STALL_SEC=240       # seconds before considering a step stalled
STUDIO_PIPELINE_MAX_SEC=2700    # 45 min max total pipeline time

# Per-project iteration limit for the fix loop
STUDIO_MAX_ITERATIONS=5

# Fernet key for encrypting stored tokens (generate once and keep secret)
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
STUDIO_TOKEN_ENCRYPTION_KEY=

# Sandbox Docker image and resource limits
STUDIO_SANDBOX_IMAGE=node:20-alpine
STUDIO_SANDBOX_MEM=512m
STUDIO_SANDBOX_CPUS=0.5
STUDIO_SANDBOX_NET=sandbox_net
STUDIO_MAX_SANDBOXES_PER_USER=3

# Vercel deploy (optional)
STUDIO_VERCEL_TOKEN=

# Gitea (optional self-hosted git)
STUDIO_GITEA_URL=http://gitea:3000
STUDIO_GITEA_ADMIN_TOKEN=
GITEA_DB_PASSWORD=
