# ==============================================================================
# aineron.ru — шаблон конфигурации (.env.example)
# Скопировать в .env и заполнить секреты. После изменения: bash deploy.sh
# ВАЖНО: комментарии только на отдельных строках — inline-комментарии после
# значения ломают парсинг env_file в docker-compose.
#
# ФЛАГИ, ВЫКЛЮЧЕННЫЕ НАМЕРЕННО (не включать без понимания последствий):
#   STUDIO_ENABLED=false      — Studio в разработке
#   TG_GIFTS=0                — тратит реальные Telegram Stars
#   TG_STYLED_BUTTONS=0       — требует Telegram Premium у владельца бота
#   MODERATION_ENABLED=0      — +1 API-вызов на каждое сообщение
#   TEXT_BILLING_ENABLED=0    — риск двойного списания, НЕ включать
#   INTERNAL_DEPLOY_ENABLED=0 — RCE-риск, НЕ включать
#   PROJECT_RERANK=0          — тяжёлая CPU-модель
# ==============================================================================


# ── Django: базовое ───────────────────────────────────────────────────────────
DEBUG=0
DJANGO_ALLOWED_HOSTS=aineron.ru www.aineron.ru localhost 127.0.0.1 web *
SECRET_KEY=

LANG=C.UTF-8
LC_ALL=C.UTF-8
PYTHONIOENCODING=utf-8

SITE_URL=https://aineron.ru
SITE_NAME=aineron.ru


# ── PostgreSQL ────────────────────────────────────────────────────────────────
# POSTGRES_* — инициализация контейнера, DB_* — подключение Django (совпадают)
POSTGRES_DB=neiro_db
POSTGRES_USER=neiro_user
POSTGRES_PASSWORD=

DB_HOST=db
DB_NAME=neiro_db
DB_USER=neiro_user
DB_PASSWORD=
DB_PORT=5432


# ── Redis ─────────────────────────────────────────────────────────────────────
# db=0 — Celery/кэш; db=2 — FSM бота (вычисляется в settings.py); db=3 — preview
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0


# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.beget.com
EMAIL_PORT=465
EMAIL_USE_SSL=True
EMAIL_USE_TLS=False
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=


# ── Платежи: Robokassa ────────────────────────────────────────────────────────
# PASS1 — подпись исходящих платежей, PASS2 — проверка вебхука.
# TEST_MODE=1 — тестовая касса, 0 — боевой режим.
ROBOKASSA_LOGIN=
ROBOKASSA_PASS1=
ROBOKASSA_PASS2=
ROBOKASSA_TEST_MODE=1


# ── AI-провайдеры ─────────────────────────────────────────────────────────────
# api.laozhang.ai — текст и изображения
LAOZHANG_API_KEY=
# apimart.ai — видео (Sora, Veo, Kling)
APIMART_API_KEY=
# tavily.com — веб-поиск (1000 req/мес бесплатно)
TAVILY_API_KEY=
# Автофолбэк laozhang<->apimart при сбое провайдера (1 = включён)
AI_PROVIDER_FALLBACK=1
# Резервный base_url laozhang (пусто = не используется)
LAOZHANG_API_URL_FALLBACK=


# ── Биллинг ───────────────────────────────────────────────────────────────────
# Минимальное списание, копейки (10 = 0,10 руб.)
MIN_CHARGE_KOPECKS=10
# Орг-биллинг: копеек за 1 звезду (100 = 1:1)
ORG_KOPECKS_PER_STAR=100
# НЕ включать: списание за текст уже в api-слое, флаг = двойное списание
TEXT_BILLING_ENABLED=0
# Премодерация сообщений (+1 API-вызов и задержка на каждое сообщение)
MODERATION_ENABLED=0


# ── STUDIO (Vibe-Coding) — выключена, в разработке ───────────────────────────
# false = /studio редиректит на главную (пробрасывается во frontend через compose)
STUDIO_ENABLED=false
# Рабочий пайплайн V3 (architect/coder/guardian)
STUDIO_V3=1
# Флаги V4 (в разработке, действуют только внутри Studio)
STUDIO_V4_TOKEN_BILLING=0
STUDIO_V4_COMMITS_CACHE=0
STUDIO_V4_PROVIDER_FALLBACK=0
STUDIO_V4_AUTOFIX=1
STUDIO_V4_STREAMING=1
STUDIO_V4_GUARDIAN_CONTEXT=1
STUDIO_V4_RU_STACK=0
STUDIO_V4_TMA=1
STUDIO_MAX_AUTOFIX=3
# GigaChat для RU-стека Studio (не подключён)
GIGACHAT_API_URL=
GIGACHAT_API_KEY=
# Деплой проектов Studio на российские хостинги (не подключены)
TIMEWEB_API_TOKEN=
SELECTEL_ACCOUNT_ID=
SELECTEL_API_KEY=
# Отдельный бот для Telegram Mini App проектов Studio
STUDIO_TMA_BOT_TOKEN=
# Gitea — git-хостинг репозиториев Studio
GITEA_DB_PASSWORD=
STUDIO_GITEA_ADMIN_TOKEN=

# E2B-превью Studio (расходов нет, пока Studio выключена)
E2B_API_KEY=
E2B_PREVIEW_STARS_PER_MIN=1
E2B_PREVIEW_DAILY_CAP_MIN=120
PREVIEW_INTERNAL_TOKEN=
PREVIEW_SERVICE_URL=http://preview_service:8001
PREVIEW_PAUSE_ENABLED=1
PREVIEW_PAUSE_GRACE=1800
PREVIEW_POOL_TARGET=2
PREVIEW_MAX_POOL_SIZE=6
E2B_TEMPLATE_NEXTJS=
E2B_TEMPLATE_PYTHON=
E2B_TEMPLATE_DJANGO=

# Режим «БД aineron» для превью (CREATE SCHEMA per project)
AINERON_DB_HOST=db
AINERON_DB_PORT=5432
AINERON_DB_NAME=neiro_db
AINERON_DB_USER=neiro_user
AINERON_DB_PASSWORD=


# ── Telegram-бот ──────────────────────────────────────────────────────────────
# 1 = смонтировать webhook /telegram/webhook/
TELEGRAM_BOT_ENABLED=0
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=aineron_bot
# Telegram ID админов через запятую
TELEGRAM_ADMIN_IDS=

# TELEGRAM SUPREMACY (S0-S8): у каждой фичи fallback на старый путь.
# TG_BUSINESS/TG_TOPICS/TG_MANAGED_BOTS инертны, пока пользователь сам
# не задействует фичу; TG_GIFTS тратит реальные Stars — включать с бюджетом;
# TG_STYLED_BUTTONS требует Premium у владельца бота.
TG_NATIVE_STREAMING=1
TG_RICH_MESSAGES=1
TG_STARS_SUBSCRIPTIONS=1
TG_AFFILIATE=1
TG_BUSINESS=1
TG_TOPICS=1
TG_MANAGED_BOTS=1
TG_GIFTS=0
TG_STYLED_BUTTONS=0

# Экономика фич бота (значения = дефолты settings.py):
# XTR_RATE — копеек за 1 Stars; RESEARCH — цена Deep Research (коп.);
# BUSINESS_REPLY — цена ответа секретаря сверх лимита; ALLOWANCE — ответов
# в тарифах Бизнес/Макс; AGENT — цена Agent Mode; CAP — дневные лимиты.
TG_XTR_RATE_KOPECKS=200
TG_GIFTS_MONTHLY_BUDGET_STARS=500
AITASK_DAILY_CAP=30
RESEARCH_PRICE_KOPECKS=1000
BUSINESS_REPLY_PRICE_KOPECKS=100
BUSINESS_TARIFF_ALLOWANCE=300
AGENT_PRICE_KOPECKS=500
MANAGEDBOT_DAILY_CAP=300


# ── Память / Project Spaces / RAG ────────────────────────────────────────────
# UNIFIED_SUPREMACY: память проекта/организации, recall прошлых чатов,
# research -> база знаний, инструменты агента, коннектор «сайт»
MEMORY_PROJECT_SCOPE=1
MEMORY_ORG_SCOPE=1
RECALL_CHATS=1
RESEARCH_TO_KB=1
AGENT_TOOLS_KB=1
CONNECTOR_WEBSITE=1
CONNECTOR_CRAWL_LIMIT=50

# Fernet-ключ шифрования токенов коннекторов. Сгенерировать один раз:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
PROJECT_CONNECTOR_FERNET_KEY=
PROJECT_AI_COMMITS=1
PROJECT_VECTOR_RAG=1
# Модель эмбеддингов (менять только с пересчётом базы)
PROJECT_EMBED_MODEL=text-embedding-3-small
PROJECT_EMBED_DIMS=1536

# RAG-лимиты: файлов на синк / символов контекста / чанков / размер чанка
PROJECT_SYNC_MAX_FILES=1000
PROJECT_INJECT_LIMIT=400000
PROJECT_TOP_K=20
PROJECT_CHUNK_SIZE=1500
# Умный чанкинг по структуре кода
PROJECT_SMART_CHUNK=1

# Knowledge intelligence / sync hardening / observability
PROJECT_FILE_SEARCH=1
PROJECT_EMBED_CACHE=1
PROJECT_KB_METRICS=1
PROJECT_FILE_VERSIONS=1
PROJECT_SYNC_POLLING=1
PROJECT_CODEBASE=1
PROJECT_PR_PROPOSALS=1
PROJECT_AUDIT_LOG=1
PROJECT_PUBLIC_HARDENING=1
PROJECT_TG_UPLOAD=1

# RAG Supremacy: гибридный поиск (RRF), адаптивный top_k, учёт диалога,
# расширение запроса дешёвой LLM, @file/@web, двухуровневый retrieval
PROJECT_HYBRID_SEARCH=1
PROJECT_RRF_K=60
PROJECT_ADAPTIVE_TOPK=1
PROJECT_CONV_SEARCH=1
PROJECT_CONV_WINDOW=4
PROJECT_QUERY_EXPANSION=1
PROJECT_EXPAND_MODEL=gpt-4o-mini
PROJECT_EXPAND_N=3
# Cross-encoder переранжирование: тяжёлая CPU-модель — только при необходимости
PROJECT_RERANK=0
PROJECT_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
PROJECT_RERANK_CANDIDATES=50
PROJECT_RERANK_TOPK=15
PROJECT_FILE_PIN=1
PROJECT_WEB_SEARCH=1
PROJECT_TWO_LEVEL=1
PROJECT_TWO_LEVEL_FILES=5

# Code Workspace: редактор кода, внешний deploy-хук (HMAC — безопасно).
# INTERNAL_DEPLOY: запуск shell-скрипта по HTTP (RCE) — НЕ включать.
PROJECT_CODE_EDITOR=1
PROJECT_DEPLOY_HOOK=1
INTERNAL_DEPLOY_ENABLED=0
INTERNAL_DEPLOY_SCRIPT=/app/deploy.sh


# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_* вшиваются при сборке образа — задаются в args сервиса frontend
# в docker-compose.yml (NEXT_PUBLIC_API_URL, NEXT_PUBLIC_SITE_URL,
# NEXT_PUBLIC_E2B_PREVIEW, NEXT_PUBLIC_YM_ID — Яндекс.Метрика,
# NEXT_PUBLIC_GA_ID — GA4), менять здесь бесполезно.

# ── Sandbox API (SANDBOX_API_PLAN.md) — публичные песочницы /api/v1/sandboxes/ ─
# Перед включением: разблокировать E2B-аккаунт и поднять preview_service
# (docker-compose --profile studio up -d preview_service)
SANDBOX_API_ENABLED=0
SANDBOX_PRICE_SMALL_KOPECKS=50
SANDBOX_PRICE_STANDARD_KOPECKS=100
SANDBOX_DAILY_CAP_MIN=240
SANDBOX_MAX_CONCURRENT_PER_USER=3
SANDBOX_MAX_CONCURRENT=10
SANDBOX_DEFAULT_TTL=300
SANDBOX_MAX_TTL=3600
SANDBOX_EXEC_TIMEOUT_MAX=300
SANDBOX_OUTPUT_LIMIT_KB=256
SANDBOX_ABUSE_RUNTIME_MIN=20
SANDBOX_ABUSE_EXEC_COUNT=50
SANDBOX_RUNRATE_ALERT_RUB=500
